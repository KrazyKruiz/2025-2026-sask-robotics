
#include <PRIZM_PRO.h>
#include <TELEOP.h> // include the PRIZM Pro library in the sketch
PRIZM prizm;              // instantiate a PRIZM object “prizm” so we can use its functions
PS4 ps4; 
EXPANSION exc; 
  int base_left = 90;
  int base_right = 90;
  int elbow = 90;
  int PowerM1; 
  int PowerM2; 
  int PowerM3; 
  int PowerM4; 
  int b_delay = 0;
void setup() {


  prizm.PrizmBegin(); 

  ps4.setDeadZone (LEFT,10);     // Sets a both Joystick Dead Zones axis range of +/- 10 about center stick
  ps4.setDeadZone(RIGHT,10);
  prizm.setMotorInvert(1,1);
  prizm.setMotorInvert(3,1);
}

void loop() {     // repeat in a loop

  ps4.getPS4();
  if(ps4.Connected){

    //motor and wheel LY is left stick and left wheels, vice versa
       PowerM1 = ps4.Motor(LY);               
       PowerM2 = ps4.Motor(RY);    
       PowerM3 = ps4.Motor(LY);               
       PowerM4 = ps4.Motor(RY);               
       prizm.setMotorPowers(PowerM1, PowerM2, PowerM3, PowerM4);
    
    if(ps4.Button(L1)){
          //lowers base arm by 10 degrees
          if (base_left >= 10 && base_right <= 170){
              base_left -= 10;
              base_right += 10;
              prizm.setServoPosition(1,base_left);
              prizm.setServoPosition(2,base_right);

              delay(200);
      }
    } if(ps4.Button(R1)){
          //raises base arm by 10 degrees
          if (base_left <= 170 && base_right >= 10){
              base_left += 10;
              base_right -= 10;
              prizm.setServoPosition(1,base_left);
              prizm.setServoPosition(2,base_right);

              delay(200);
            
          }
        } if(ps4.Button(L2)){
          //lowers elbow by 10 degrees
          if (elbow <= 170){
             elbow += 10;
             prizm.setServoPosition(3,elbow);
             delay(200);
        }
      } if(ps4.Button(R2)){
          //raises eblow by 10 degrees
          if (elbow >= 10){
            
             elbow -= 10;
             prizm.setServoPosition(3,elbow);
             delay(200);
          }
      } if(ps4.Button(CROSS)){
          //opens claw
             prizm.setServoPosition(4,170);
             delay(200);
        } if(ps4.Button(CIRCLE)){
          //opens claw
             prizm.setServoPosition(4,10);
             delay(200);
             
     } if(ps4.Button(SQUARE)){

      exc.setMotorPower(1,1,125);
      delay(50);

      exc.setMotorPower(1,1,25);
      exc.setMotorDegree(1,1,25,2);
      delay(750 + b_delay);
      
      exc.setMotorPower(1,1,125);
      delay(1000);
      
      exc.setMotorDegree(1,1,40,2);
      exc.setMotorPower(1,1,-35);
      delay(350 + b_delay);
      
      exc.setMotorPower(1,1,0);
      delay(500);
      b_delay = 0;
           
     }// if(ps4.Button(TRIANGLE)){
      //exc.setMotorDegree(1,1,50,-100);
      //Delay(500);
      //exc.setMotorPower(1,1,-50);
      //delay(500);
      //exc.setMotorPower(1,1,125);
//}
      
      if(ps4.Button(UP)){
          b_delay += 50;
          ps4.setRumble(FAST);
          delay(100);
          ps4.setRumble(STOP);
      }
       if(ps4.Button(DOWN)){
          b_delay = 0;
          ps4.setRumble(FAST);
          delay(50);
          ps4.setRumble(STOP);
      }

}
}
